@model IEnumerable<IT15_LabExam_Farase.Models.Employees>

@{
    ViewData["Title"] = "Employees";
}

<div class="table-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div>
            <h1 class="h3 mb-1">Employees</h1>
            <p class="text-muted mb-0">Manage employee records for TechCore Solutions.</p>
        </div>
        <a class="btn btn-primary" asp-action="Create">Add Employee</a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.EmployeeId)</th>
                    <th>Name</th>
                    <th>@Html.DisplayNameFor(model => model.Position)</th>
                    <th>@Html.DisplayNameFor(model => model.Department)</th>
                    <th>@Html.DisplayNameFor(model => model.DailyRate)</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.EmployeeId</td>
                    <td>@item.FullName</td>
                    <td>@item.Position</td>
                    <td>@item.Department</td>
                    <td>@item.DailyRate.ToString("C2")</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                            <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@item.EmployeeId">Edit</a>
                            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.EmployeeId">Delete</a>
                            <a class="btn btn-outline-primary" asp-controller="Payrolls" asp-action="Index" asp-route-employeeId="@item.EmployeeId">Payroll</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>