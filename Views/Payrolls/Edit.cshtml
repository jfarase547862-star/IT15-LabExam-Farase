@model IT15_LabExam_Farase.Models.Payroll

@{
    ViewData["Title"] = "Edit Payroll";
}

<div class="form-card mx-auto" style="max-width: 760px;">
    <h1 class="h3 mb-1">Edit Payroll</h1>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="PayrollId" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="EmployeeId" class="form-label"></label>
                <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeId">
                    <option value="">Choose employee</option>
                </select>
                <span asp-validation-for="EmployeeId" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="PayrollDate" class="form-label"></label>
                <input asp-for="PayrollDate" class="form-control" type="date" />
                <span asp-validation-for="PayrollDate" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DaysWorked" class="form-label"></label>
                <input asp-for="DaysWorked" class="form-control" type="number" min="0" />
                <span asp-validation-for="DaysWorked" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Deduction" class="form-label"></label>
                <input asp-for="Deduction" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="Deduction" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-4 row g-3">
            <div class="col-md-4">
                <label class="form-label">Gross Pay</label>
                <input class="form-control" value="@Model.GrossPay.ToString("C2")" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label">Net Pay</label>
                <input class="form-control" value="@Model.NetPay.ToString("C2")" readonly />
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}