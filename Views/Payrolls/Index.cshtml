@model IEnumerable<IT15_LabExam_Farase.Models.Payroll>

@{
    ViewData["Title"] = "Payroll";
}

<div class="table-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-controller="Employees" asp-action="Index"><i class="bi bi-person-fill"></i> Employees</a>
            <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus-circle-fill"></i> Add Payroll</a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Payroll ID</th>
                    <th>Employee</th>
                    <th>Date</th>
                    <th>Days Worked</th>
                    <th>Gross Pay</th>
                    <th>Deduction</th>
                    <th>Net Pay</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.PayrollId</td>
                    <td>@item.Employee?.FullName</td>
                    <td>@item.PayrollDate.ToString("MMM dd, yyyy")</td>
                    <td>@item.DaysWorked</td>
                    <td>@item.GrossPay.ToString("C2")</td>
                    <td>@item.Deduction.ToString("C2")</td>
                    <td>@item.NetPay.ToString("C2")</td>
                    <td class="text-end">
                        <div class="btn-group btn-group-sm" role="group">
                            <a class="btn btn-outline-secondary" asp-action="Edit" asp-route-id="@item.PayrollId"><i class="bi bi-pencil"></i> Edit</a>
                            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.PayrollId"><i class="bi bi-trash"></i> Delete</a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>